# LOCAL ON environment template
# 1) Copy this file to `.env`
# 2) Fill required values
# 3) Keep exactly one DATABASE_URL/CITYDATA_API_KEY active

# -------------------------------------------------------------------
# LOCAL (active defaults)
# -------------------------------------------------------------------
DATABASE_URL=mysql+aiomysql://localon:your_password@127.0.0.1:3306/local_on
CITYDATA_API_KEY=your_seoul_openapi_key

# Optional overrides
CITYDATA_URL_TEMPLATE=http://openapi.seoul.go.kr:8088/{api_key}/xml/citydata/1/5/{area_name}
SDOT_URL_TEMPLATE=http://openapi.seoul.go.kr:8088/{api_key}/xml/{service_name}/1/{limit}
SDOT_SERVICE_NAME=sDoTPeople
SDOT_LIMIT=1000
